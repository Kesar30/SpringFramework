<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:p="http://www.springframework.org/schema/p" xmlns:value="http://www.springframework.org/schema/c"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

<!--    b class bean-->
    <bean name="classB" class="com.reference.B" p:y="100" />
<!--    a class bean-->
    <bean name="classA" class="com.reference.A">
        <property name="x" value="100" />
        <property name="ob" ref="classB" />

    </bean>


</beans>